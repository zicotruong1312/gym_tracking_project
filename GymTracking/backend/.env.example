PORT=5000
MONGODB_URI=mongodb://localhost:27017/gymtracking
JWT_SECRET=your-secret-key

# CORS origins for browser + Socket.IO (comma-separated)
CLIENT_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Optional: AI chat — ưu tiên Gemini (SDK @google/generative-ai). Restart server sau khi sửa.
# Lấy key: https://aistudio.google.com/apikey
# GEMINI_API_KEY=your-key
# Free tier: nếu gemini-2.0-flash báo 429 / limit:0 → dùng: GEMINI_MODEL=gemini-1.5-flash-002
# Có thể bỏ hẳn GEMINI_MODEL — server sẽ tự thử gemini-2.0-flash, 2.5-flash, 1.5-flash-002…
# Tránh: gemini-1.5-flash (không hậu tố) — thường báo 404 trên API mới.
# Nếu lỗi 403: trong Google AI Studio → API key → Application restrictions = **None** (backend Node không dùng "Websites").
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
